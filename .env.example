# Postgres password (docker-compose creates the db with it)
DB_PASSWORD=change-me
# Long random string: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me
# Public URL the app is reached at — auth REJECTS sign-in/sign-up from any other origin.
# If you change APP_PORT (host port, default 3000), the port here must match.
APP_URL=http://localhost:3000
# Host port for local access — pick one clear of your dev ports (3000-3005, 5173…)
# APP_PORT=9700

# --- Going public via Cloudflare Tunnel (see README) ---
# Connector token from Zero Trust → Networks → Tunnels (docker connector)
# TUNNEL_TOKEN=
# Extra origins auth should trust besides APP_URL (comma-separated),
# e.g. keep localhost login working while APP_URL is the public https URL
# TRUSTED_ORIGINS=http://localhost:3000
# Set true once your household members are registered — blocks new sign-ups
# DISABLE_SIGNUPS=false
