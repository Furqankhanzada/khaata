# Postgres password (docker-compose creates the db with it)
DB_PASSWORD=change-me
# Long random string: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me
# Public URL the app is reached at — auth REJECTS sign-in/sign-up from any other origin.
# If you change APP_PORT (host port, default 3000), the port here must match.
APP_URL=http://localhost:3000
# APP_PORT=3000
